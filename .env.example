# ─────────────────────────────────────────────────────────────
# Configuración de Bola 8 Barbería — Bot de WhatsApp
# Copia este archivo a `.env` y completa los valores reales.
# ─────────────────────────────────────────────────────────────

# Cadena de conexión a PostgreSQL
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/BASE_DE_DATOS?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bola8?schema=public"

# Token permanente (o de larga duración) de la app de WhatsApp Cloud API
WHATSAPP_TOKEN=

# ID del número de teléfono de WhatsApp (Phone Number ID, NO el número en sí)
WHATSAPP_PHONE_NUMBER_ID=

# Token de verificación que tú defines y registras en el panel de Meta
WHATSAPP_VERIFY_TOKEN=mi_token_de_verificacion_secreto

# App Secret de la app de Meta — se usa para validar la firma x-hub-signature-256
WHATSAPP_APP_SECRET=

# Puerto donde corre el servidor Express
PORT=3000

# Zona horaria usada por el planificador de recordatorios y validación de fechas
TZ=America/Mexico_City
